      { "key": "cta_label", "label": "CTA Label", "type": "text", "required": true, "max": 40, "default": "Get Started" },
      { "key": "cta_url", "label": "CTA URL", "type": "url", "required": true, "default": "https://example.com" },
      { "key": "background_color", "label": "Background Color", "type": "color", "required": true, "default": "#0F172A" },
      { "key": "show_badge", "label": "Show Badge", "type": "toggle", "required": false, "default": true },
      { "key": "badge_text", "label": "Badge Text", "type": "text", "required": false, "max": 60, "default": "Base Template" }
